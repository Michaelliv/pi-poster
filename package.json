{
  "name": "pi-poster",
  "version": "0.1.0",
  "description": "🎨 Poster integration for pi — render React posters to PNG/SVG/PDF/JPG/WebP from an agent session.",
  "keywords": [
    "pi-package",
    "poster",
    "render",
    "visualization"
  ],
  "pi": {
    "extensions": [
      "extensions/poster-make"
    ],
    "skills": [
      "skills"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Michaelliv/pi-poster.git"
  },
  "homepage": "https://github.com/Michaelliv/pi-poster#readme",
  "bugs": {
    "url": "https://github.com/Michaelliv/pi-poster/issues"
  },
  "scripts": {
    "lint": "biome check extensions/",
    "lint:fix": "biome check --write extensions/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14"
  },
  "dependencies": {
    "poster-ai": "^0.4.0",
    "react-is": "^19.2.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "license": "MIT"
}
